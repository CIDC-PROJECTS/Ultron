# Ultron (Express API)
# MongoDB is still used for routes you haven't migrated yet (e.g. categories).
MONGO_URI=mongodb://localhost:27017/fc
PORT=5000

# Supabase (required for menu/orders/tables/settings + image uploads)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional (used for default admin credentials on first run)
ADMIN_EMAIL=admin@canteen.edu
ADMIN_PASSWORD=admin123

# Supabase Storage bucket (must exist)
SUPABASE_MENU_IMAGES_BUCKET=menu-images
